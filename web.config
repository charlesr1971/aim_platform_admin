<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- Rule 1: Route the Webhook API to Port 8000 -->
                <rule name="Stripe Webhook Proxy" stopProcessing="true">
                    <match url="^api/webhook(.*)" />
                    <action type="Rewrite" url="http://127.0.0{R:1}" />
                </rule>

                <!-- Rule 2: Route everything else to the Streamlit Dashboard on Port 8501 -->
                <rule name="Streamlit Dashboard Proxy" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://127.0.0{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
