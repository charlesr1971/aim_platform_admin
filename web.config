<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- 1. API TRAFFIC: Route /api/webhook and /health to the Webhook Service (Port 8000) -->
                <rule name="Stripe Webhook Proxy" stopProcessing="true">
                    <match url="^(api/webhook|health)(.*)" />
                    <action type="Rewrite" url="http://127.0.0{R:1}{R:2}" />
                </rule>

                <!-- 2. UI TRAFFIC: Route everything else to the Streamlit Dashboard (Port 8501) -->
                <rule name="Streamlit Dashboard Proxy" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://127.0.0{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
