<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- 1. API TRAFFIC: Route specific paths to the Webhook Service (Port 8000) -->
                <rule name="Stripe Webhook Proxy" stopProcessing="true">
                    <match url="^(api/webhook|health)(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:8000/{R:0}" />
                </rule>

                <!-- 2. UI TRAFFIC: Route EVERYTHING ELSE to Streamlit (Port 8501) -->
                <rule name="Streamlit Dashboard Proxy" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:8501/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
