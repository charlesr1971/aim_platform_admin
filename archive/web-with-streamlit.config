<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- 1. UI TRAFFIC: Route everything else to the Streamlit Dashboard (Port 8501) -->
                <rule name="Streamlit Dashboard Proxy" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:8501/{R:1}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
